<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SeverityBeacon.Gui.App">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Aglet Mono" />
      <Setter Property="Background">
        <SolidColorBrush Color="#31193F" />
      </Setter>
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#FFF7E8" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#452257CC" />
      <Setter Property="BorderBrush" Value="#744D88" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="BoxShadow" Value="0 10 30 0 #55000000" />
    </Style>
    <Style Selector="Button.header-toggle">
      <Setter Property="Background" Value="#5C2F73" />
      <Setter Property="Foreground" Value="#FFF7E8" />
      <Setter Property="BorderBrush" Value="#8E63A5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="22,12" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Application.Styles>
</Application>
