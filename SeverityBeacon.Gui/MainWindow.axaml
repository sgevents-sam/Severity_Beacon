<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:SeverityBeacon.Gui.ViewModels"
        mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="780"
        x:Class="SeverityBeacon.Gui.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Width="860"
        Height="780"
        MinWidth="520"
        MinHeight="560"
        Icon="avares://SeverityBeacon.Gui/tray-roundal.png"
        Title="SeverityBeacon">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="22">
      <Border Classes="panel" Padding="20" Margin="0,0,0,16">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" RowDefinitions="Auto,Auto">
          <Button Classes="header-toggle"
                  Content="{Binding PollingToggleLabel}"
                  Click="TogglePollingClick"
                  Height="54"
                  MinWidth="180"
                  FontSize="18"
                  FontWeight="SemiBold"
                  HorizontalAlignment="Left" />
          <Border Grid.Column="1"
                  Margin="14,0,0,0"
                  Background="{Binding StatusBadgeBackground}"
                  BorderBrush="{Binding StatusBadgeBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="999"
                  Padding="22,12"
                  Height="54"
                  MinWidth="180"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#FFF7E8"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <Image Grid.Column="3"
                 Width="112"
                 Height="112"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Source="avares://SeverityBeacon.Gui/tray-roundal.png"
                 Stretch="Uniform" />
          <TextBlock Grid.Row="1"
                     Grid.ColumnSpan="4"
                     Margin="0,16,0,0"
                     Text="{Binding LastError}"
                     Foreground="#FFB5B5"
                     TextWrapping="Wrap"
                     IsVisible="{Binding HasError}" />
        </Grid>
      </Border>

      <StackPanel Grid.Row="1" Spacing="16">
        <Border Classes="panel">
          <StackPanel Spacing="18">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Margin="0,0,12,12" Text="Saved Profile" VerticalAlignment="Center" Foreground="#D0D8E2" />
              <ComboBox Grid.Column="1"
                        Margin="0,0,0,12"
                        ItemsSource="{Binding Profiles}"
                        SelectedItem="{Binding SelectedProfile}"
                        SelectionChanged="ProfileSelectionChanged">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Grid.Row="1" Margin="0,0,12,12" Text="Desk Lamp Mode" VerticalAlignment="Center" Foreground="#D0D8E2" />
              <ToggleSwitch Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" IsChecked="{Binding IsDeskLampEnabled}" OnContent="On" OffContent="Off" />

              <TextBlock Grid.Row="2" Margin="0,0,12,0" Text="Current Beacon" VerticalAlignment="Center" Foreground="#D0D8E2" />
              <Border Grid.Row="2"
                      Grid.Column="1"
                      Width="58"
                      Height="58"
                      HorizontalAlignment="Left"
                      CornerRadius="10"
                      BorderBrush="#B896C8"
                      BorderThickness="2">
                <Border.Background>
                  <SolidColorBrush Color="{Binding CurrentBeaconColor}" />
                </Border.Background>
              </Border>
            </Grid>

            <Border Background="#3D204D" BorderBrush="#744D88" BorderThickness="1" CornerRadius="14" Padding="14">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="section-title" Text="Override" />
                  <ToggleSwitch Grid.Column="1"
                                IsChecked="{Binding IsManualOverrideEnabled}"
                                Checked="ManualOverrideChecked"
                                Unchecked="ManualOverrideUnchecked"
                                OnContent="On"
                                OffContent="Off" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                  <ColorPicker Width="88"
                               Height="48"
                               Margin="0,0,14,0"
                               Color="{Binding ManualOverrideColor}"
                               IsAlphaEnabled="False"
                               IsAlphaVisible="False"
                               IsEnabled="{Binding IsManualOverrideEnabled}" />
                  <TextBox Grid.Column="1"
                           Text="{Binding ManualOverrideHex}"
                           Watermark="#FFFFFF"
                           Margin="0,0,14,0"
                           IsEnabled="{Binding IsManualOverrideEnabled}" />
                  <TextBlock Grid.Column="2"
                             VerticalAlignment="Center"
                             Text="Live"
                             Foreground="#D0D8E2"
                             IsVisible="{Binding IsManualOverrideEnabled}" />

                  <WrapPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0" Orientation="Horizontal">
                    <Button Content="Disaster"
                            Tag="disaster"
                            Classes="header-toggle"
                            Click="ToggleSeverityOverrideClick"
                            MinWidth="110"
                            IsEnabled="{Binding IsManualOverrideEnabled}" />
                    <Button Content="High"
                            Tag="high"
                            Margin="10,0,0,0"
                            Classes="header-toggle"
                            Click="ToggleSeverityOverrideClick"
                            MinWidth="110"
                            IsEnabled="{Binding IsManualOverrideEnabled}" />
                    <Button Content="Average"
                            Tag="average"
                            Margin="10,0,0,0"
                            Classes="header-toggle"
                            Click="ToggleSeverityOverrideClick"
                            MinWidth="110"
                            IsEnabled="{Binding IsManualOverrideEnabled}" />
                    <Button Content="Warning"
                            Tag="warning"
                            Margin="10,0,0,0"
                            Classes="header-toggle"
                            Click="ToggleSeverityOverrideClick"
                            MinWidth="110"
                            IsEnabled="{Binding IsManualOverrideEnabled}" />
                  </WrapPanel>
                  <TextBlock Grid.Row="1"
                             Grid.ColumnSpan="3"
                             Margin="0,56,0,0"
                             Text="{Binding ActiveOverrideDisplay}"
                             Foreground="#D0D8E2"
                             IsVisible="{Binding HasActiveOverride}" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

      </StackPanel>

      <Grid Grid.Row="2" Margin="0,16,0,0" ColumnDefinitions="*,Auto,Auto">
        <Button Grid.Column="1"
                Classes="header-toggle"
                Content="Settings"
                Click="OpenSettingsClick"
                Height="54"
                MinWidth="140"
                HorizontalAlignment="Right" />
        <Button Grid.Column="2"
                Margin="14,0,0,0"
                Classes="header-toggle"
                Content="Hide GUI"
                Click="HideGuiClick"
                Height="54"
                MinWidth="140"
                HorizontalAlignment="Right" />
      </Grid>

      <Border Grid.Row="3"
              Margin="0,16,0,0"
              Padding="12,10"
              Background="#24122F88"
              BorderBrush="#744D88"
              BorderThickness="1"
              CornerRadius="12">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
          <TextBlock Text="Severity Beacon 3.1"
                     Foreground="#D0D8E2"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="© SG Event Services 2026"
                     Foreground="#D0D8E2"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
          <Button Grid.Column="2"
                  Content="sgeventservices.com"
                  Click="OpenWebsiteClick"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="#FFF7E8"
                  FontWeight="SemiBold"
                  Padding="0"
                  HorizontalAlignment="Right" />
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</Window>
